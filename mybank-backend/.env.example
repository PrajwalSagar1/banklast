# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# Local: mongodb://localhost:27017/mybank
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/mybank
MONGO_URI=mongodb://localhost:27017/mybank

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# CORS Configuration (for frontend URL)
FRONTEND_URL=http://localhost:5173

# For production:
# PORT=5000
# NODE_ENV=production
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/mybank
# FRONTEND_URL=https://yourfrontend.com
# JWT_SECRET=use_a_strong_random_secret_key
